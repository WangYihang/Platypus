# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Build artifacts
build/
dist/
# The platypus-server embeds the React bundle from internal/webui/dist/
# via //go:embed. We commit the stub index.html + .gitkeep so a fresh
# checkout still compiles; the real bundle is staged on top by
# `make web-ui-embed`. Re-include the directory itself here so the
# nested internal/webui/.gitignore can manage the stub vs. build
# artifacts inside it.
!internal/webui/dist/

# Stray binaries at repo root left by `go build ./...` — the
# Makefile puts proper builds under build/, but ad-hoc local
# invocations drop them here.
/platypus-server
/platypus-agent
/platypus-cli

# Cargo build output for example plugins. The .wasm artefacts are
# build outputs; we don't commit them. System plugin bundles under
# internal/agent/plugin/system/embedded/ are signed + checked in
# deliberately and not affected by this rule.
#
# Cargo.lock files ARE checked in even though they're build artefacts:
# the publisher container bind-mounts /workspace read-only + cargo
# refuses to build a crate without a Cargo.lock unless it can generate
# one (and it can't on a RO mount). Committing them also pins the
# toolchain dep tree for reproducible CI builds. Compile/sign in the
# publisher's writable cache via CARGO_TARGET_DIR.
example/plugins/*/target/

# Wails desktop — un-ignore project scaffold under desktop/build/
# (global build/ rule above would otherwise hide platform configs).
# Desktop-specific build/bin, node_modules, frontend/dist live in desktop/.gitignore.
!desktop/build/
!desktop/build/**

# Config file
config.yml
config-v*.yml

# Visual Studio Code
.vscode/

# Vagrant
.vagrant/

# air
tmp/

# SQLite
*.sqlite3
*.db
*.db-journal

# Playwright
.playwright-mcp/
/*.png
# Playwright e2e — paths matched anywhere in the tree because a spec
# accidentally invoked from desktop/frontend/ leaves its artefacts
# there instead of in e2e/.
**/test-results/
**/playwright-report/
**/.playwright/
e2e/node_modules/

# Log files
*.log

# config file
config.yaml

# codex
.codex