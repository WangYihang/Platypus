# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Build artifacts
build/
dist/

# Stray binaries at repo root left by `go build ./...` — the
# Makefile puts proper builds under build/, but ad-hoc local
# invocations drop them here.
/platypus-server
/platypus-agent

# Wails desktop — un-ignore project scaffold under desktop/build/
# (global build/ rule above would otherwise hide platform configs).
# Desktop-specific build/bin, node_modules, frontend/dist live in desktop/.gitignore.
!desktop/build/
!desktop/build/**

# Config file
config.yml
config-v*.yml

# Visual Studio Code
.vscode/

# Vagrant
.vagrant/

# air
tmp/

# SQLite
*.sqlite3
*.db
*.db-journal

# Playwright
.playwright-mcp/
/*.png
# Playwright e2e
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/.playwright/

# Log files
*.log

# config file
config.yaml

# codex
.codex