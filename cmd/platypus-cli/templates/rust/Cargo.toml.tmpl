[package]
name = "{{.CrateName}}"
version = "{{.Version}}"
edition = "2021"
authors = ["{{.AuthorName}} <{{.AuthorEmail}}>"]
license = "{{.License}}"
description = "{{.Description}}"
publish = false

[lib]
crate-type = ["cdylib"]

[dependencies]
extism-pdk = "1.4"
{{- if .WithConfig }}
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
{{- end }}

[profile.release]
opt-level = "z"
lto = true
codegen-units = 1
strip = true
panic = "abort"
