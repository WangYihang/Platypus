package main

import (
{{- if .WithConfig }}
	"errors"
	"strings"

{{- end }}
	"github.com/extism/go-pdk"

	platypus "github.com/WangYihang/Platypus/sdk/go/platypus-plugin"
)
{{- if .WithConfig }}

// helloConfig mirrors the manifest's config.schema. Fields are
// optional; missing JSON keys fall back to Go zero values which
// the plugin replaces with the schema defaults inline.
type helloConfig struct {
	Greeting string `json:"greeting"`
	Shout    bool   `json:"shout"`
}
{{- end }}

//export hello
func hello() int32 {
	name := string(pdk.Input())
	if name == "" {
		name = "world"
	}
{{- if .WithConfig }}

	cfg := helloConfig{Greeting: "Hello"}
	if err := platypus.ConfigInto(&cfg); err != nil && !errors.Is(err, platypus.ErrNoConfig) {
		platypus.LogInfof("{{.ID}}: config decode failed (%v); using defaults", err)
	}
	if cfg.Greeting == "" {
		cfg.Greeting = "Hello"
	}

	out := cfg.Greeting + ", " + name + " from {{.ID}}!"
	if cfg.Shout {
		out = strings.ToUpper(out)
	}
{{- else }}

	out := "Hello, " + name + " from {{.ID}}!"
{{- end }}
	platypus.LogInfof("{{.ID}} invoked name=%s reply=%s", name, out)
	pdk.OutputString(out)
	return 0
}

// main is required by TinyGo's wasi target. Empty body is fine; the
// runtime never invokes it on a plugin module.
func main() {}
