api_version: 1
id: {{.ID}}
name: {{.Name}}
version: {{.Version}}
author:
  name: {{.AuthorName}}
  email: {{.AuthorEmail}}
license: {{.License}}
description: |
  {{.Description}}

runtime:
  type: wasm
  entry: {{.EntryWasm}}
  abi: extism/1
  lang: go

rpc:
  - name: hello
    request:  { proto: bytes }
    response: { proto: bytes }

{{- if .CapabilitiesYAML }}
capabilities:
{{.CapabilitiesYAML}}
{{- end }}
{{- if .WithConfig }}

# Optional install-time configuration. The wizard renders this
# as a form: "Greeting prefix" (string), "Shout" (boolean toggle).
# Operators who don't override the defaults get "Hello, <name>!".
# See docs/plugins/CONFIG_AUTHORING.md for the deeper guide.
config:
  schema_version: 1
  schema:
    type: object
    properties:
      greeting:
        type: string
        description: "Word prefixed before the name. Default: Hello"
        default: "Hello"
      shout:
        type: boolean
        description: "Uppercase the entire greeting."
        default: false
  defaults:
    greeting: "Hello"
    shout: false
{{- end }}

resources:
  max_memory_mb: 16
  max_invocation_ms: 5000

signature:
  algo: minisign-ed25519
  key_id: REPLACE_WITH_YOUR_KEY_ID
  sig_file: {{.EntryWasm}}.minisig
